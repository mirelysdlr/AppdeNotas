package com.example.appsdenotas_20241742;

import android.os.Bundle;
import androidx.fragment.app.Fragment;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.*;

public class FragmentAgregar extends Fragment {

    EditText etTitulo, etDescripcion;
    Button btnGuardar;
    DBHelper db;

    public FragmentAgregar() {
        // constructor vacío obligatorio
    }

    @Override
    public View onCreateView(LayoutInflater inflater, ViewGroup container,
                             Bundle savedInstanceState) {

        View v = inflater.inflate(R.layout.fragment_agregar, container, false);

        etTitulo = v.findViewById(R.id.etTitulo);
        etDescripcion = v.findViewById(R.id.etDescripcion);
        btnGuardar = v.findViewById(R.id.btnGuardar);

        db = new DBHelper(getContext());

        btnGuardar.setOnClickListener(view -> {

            String titulo = etTitulo.getText().toString();
            String desc = etDescripcion.getText().toString();

            if(titulo.isEmpty() || desc.isEmpty()){
                Toast.makeText(getContext(),"Completa los campos",Toast.LENGTH_SHORT).show();
                return;
            }

            db.insertar(titulo, desc, "");

            Toast.makeText(getContext(),"Nota guardada",Toast.LENGTH_SHORT).show();

            etTitulo.setText("");
            etDescripcion.setText("");
        });

        return v;
    }
}